# Local dev: copy appsettings.example.json → appsettings.json rồi điền config của bạn
#
# Copy các biến sau vào Render Dashboard → Web Service → Environment
# Format: KEY=value (trên Render chỉ cần Key và Value riêng)

# --- Bắt buộc ---
ASPNETCORE_ENVIRONMENT=Production

# Database Somee (Production dùng SomeeConnection)
ConnectionStrings__SomeeConnection=Server=RentalManagementDatabase.mssql.somee.com;Database=RentalManagementDatabase;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;Encrypt=True;MultipleActiveResultSets=true

# JWT
Jwt__Key=YOUR_JWT_SECRET_AT_LEAST_32_CHARS
Jwt__Issuer=RentalManagementAPI
Jwt__Audience=RentalManagementClient
Jwt__ExpiryInDays=7

# Azure Blob Storage (lưu ảnh production)
FileStorage__Provider=Azure
AzureStorage__ConnectionString=DefaultEndpointsProtocol=https;AccountName=rentalstorage2026;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net
AzureStorage__ContainerName=rental-uploads

# Google OAuth (nếu dùng đăng nhập Google)
Google__ClientId=730567914436-gosvf2jho38fh173a7hrin2kshfvb8fg.apps.googleusercontent.com

# CORS — URL frontend trên Render (phân cách bằng dấu phẩy, không có khoảng trắng thừa)
# Localhost origins vẫn được phép mặc định; chỉ cần thêm URL production ở đây.
Cors__AllowedOrigins=https://your-frontend.onrender.com
